# Database (Vercel Postgres)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Auth
JWT_SECRET=your-random-secret-key-change-this

# Meta (Facebook) Conversions API
META_PIXEL_ID=
META_CAPI_TOKEN=
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Events API
TIKTOK_PIXEL_ID=
TIKTOK_CAPI_TOKEN=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Reddit Conversions API
REDDIT_PIXEL_ID=
REDDIT_CAPI_TOKEN=
NEXT_PUBLIC_REDDIT_PIXEL_ID=

NEXT_PUBLIC_SITE_URL=https://basedresearch.com

# Secret used to authenticate Vercel Cron invocations of /api/cron/*.
CRON_SECRET=your-cron-secret

# ── Payment processor ──────────────────────────────────────────
# This template ships WITHOUT a payment processor. Order creation works
# out of the box (orders are written as `unpaid`); collecting money is up
# to you. To wire a processor:
#   1. Add its keys here (e.g. a secret key + webhook signing secret).
#   2. Create the charge / checkout session in src/app/api/checkout/route.ts.
#   3. Confirm payment in a webhook under /api/webhooks/, flip the order to
#      paid, and run fulfillment.
#   4. Allowlist its script/frame/connect hosts in the CSP (next.config.ts).

# Image generation (KIE.ai) — used by scripts/gen-*.ts for product imagery
KIE_API_KEY=your-kie-api-key

# Comma-separated lowercased emails excluded from customer follow-up / recovery SMS
EXCLUDED_INTERNAL_EMAILS=ops@example.com,qa@example.com
